import numpy as np
X=np.array([[0,0],[0,1],[1,0],[1,1]])
Y=np.array([[0],[1],[1],[0]])
W1=np.random.rand(2,2);W2=np.random.rand(2,1)
for _ in range(1000):
    Z1=X.dot(W1);A1=1/(1+np.exp(-Z1))
    Z2=A1.dot(W2);A2=1/(1+np.exp(-Z2))
    W2+=A1.T.dot(Y-A2)*0.1;W1+=X.T.dot((Y-A2).dot(W2.T))*0.1
print(A2.round())
